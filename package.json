{
  "name": "my-claude-code",
  "version": "0.1.0",
  "description": "My implementation of Claude Code CLI",
  "type": "module",
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "dev": "bun --env-file=.env run src/entrypoints/cli.tsx",
    "chat": "bun --env-file=.env run src/entrypoints/cli.tsx chat",
    "build": "bun run build.ts",
    "test": "bun test",
    "typecheck": "bun run tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/react": "^19.2.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "chalk": "^5.6.2",
    "ink": "^7.0.1",
    "openai": "^6.34.0",
    "react": "^19.2.4",
    "react-reconciler": "^0.33.0"
  }
}